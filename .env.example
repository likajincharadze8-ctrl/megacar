# ---- MegaCars environment (TEMPLATE) ----
# Copy these keys into your host's Environment Variables (e.g. Render). Do NOT commit real secrets.

# Cloud MongoDB connection string from Atlas (Connect -> Drivers). Put your real password in,
# and keep the database name /mai_database before the "?".
MONGO_URI=mongodb+srv://megacars:YOUR_PASSWORD@cluster0.laivd7c.mongodb.net/mai_database?appName=Cluster0

# Strong random secret for login tokens (use a long random string; keep it private).
JWT_SECRET=replace_with_a_long_random_secret

# First admin account — created automatically on first boot if no admin exists yet.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# Set to "production" once deployed (enables secure cookies)
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
